{
  "$schema": "https://biomejs.dev/schemas/2.5.2/schema.json",
  "assist": {
    "enabled": true,
    "includes": ["*", "scripts/**", "src/**", "tests/**"],
    "actions": {
      "source": {
        "preset": "all",
        "useSortedKeys": "off"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "includes": ["*", "scripts/**", "src/**", "tests/**"],
    "attributePosition": "auto",
    "bracketSameLine": true,
    "bracketSpacing": true,
    "delimiterSpacing": false,
    "expand": "auto",
    "indentStyle": "space",
    "indentWidth": 2,
    "lineEnding": "auto",
    "lineWidth": 160,
    "trailingNewline": true
  },
  "javascript": {
    "formatter": {
      "arrowParentheses": "always",
      "jsxQuoteStyle": "single",
      "operatorLinebreak": "after",
      "quoteProperties": "asNeeded",
      "quoteStyle": "single",
      "semicolons": "asNeeded",
      "trailingCommas": "none"
    }
  },
  "json": {
    "formatter": {
      "trailingCommas": "none"
    }
  },
  "linter": {
    "enabled": true,
    "includes": ["src/**"],
    "rules": {
      "a11y": {
        "preset": "all"
      },
      "complexity": {
        "preset": "all",
        "noExcessiveCognitiveComplexity": "off",
        "noExcessiveLinesPerFunction": "off",
        "useMaxParams": "off"
      },
      "correctness": {
        "preset": "all",
        "noProcessGlobal": "off",
        "noVoidTypeReturn": "off",
        "useImportExtensions": "off",
        "useSingleJsDocAsterisk": "off"
      },
      "nursery": {
        "preset": "all"
      },
      "performance": {
        "preset": "all",
        "noBarrelFile": "off",
        "noDelete": "off",
        "noReExportAll": "off"
      },
      "security": {
        "preset": "all"
      },
      "style": {
        "preset": "all",
        "noContinue": "off",
        "noEnum": "off",
        "noExcessiveClassesPerFile": "off",
        "noExcessiveLinesPerFile": "off",
        "noHeadElement": "off",
        "noHexColors": "off",
        "noImplicitBoolean": "off",
        "noIncrementDecrement": "off",
        "noInferrableTypes": "off",
        "noJsxLiterals": "off",
        "noNamespace": "off",
        "noProcessEnv": "off",
        "noTernary": "off",
        "noUnusedTemplateLiteral": "off",
        "noValueAtRule": "off",
        "noVueOptionsApi": "off",
        "useAtIndex": "off",
        "useBlockStatements": "off",
        "useCollapsedElseIf": "off",
        "useCollapsedIf": "off",
        "useComponentExportOnlyModules": "off",
        "useConsistentCurlyBraces": "off",
        "useConsistentGraphqlDescriptions": "off",
        "useConst": "off",
        "useDestructuring": "off",
        "useExportsLast": "off",
        "useNamingConvention": "off",
        "useSingleVarDeclarator": "off",
        "useTemplate": "off",
        "useUnifiedTypeSignatures": "off"
      },
      "suspicious": {
        "preset": "all",
        "noConfusingVoidType": "off",
        "noConsole": "off",
        "noExplicitAny": "off",
        "noForIn": "off",
        "noShadow": "off",
        "noThenProperty": "off",
        "useAwait": "off",
        "useErrorMessage": "off",
        "useGuardForIn": "off"
      }
    }
  },
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "defaultBranch": "master",
    "useIgnoreFile": true
  }
}
